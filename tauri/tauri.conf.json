{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Facebonk",
  "version": "0.1.0",
  "identifier": "to.holepunch.facebonk",
  "build": {
    "beforeDevCommand": "npm run sidecar:debug",
    "beforeBuildCommand": "npm run sidecar:release",
    "frontendDist": "../renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Facebonk",
        "width": 900,
        "height": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/bare"],
    "resources": ["resources/bare/**/*", "resources/pear.app.json"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
