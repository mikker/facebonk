{
  "name": "facebonk",
  "version": "0.1.0",
  "description": "Peer-to-peer identity manager with shared core, CLI, and local desktop app",
  "type": "module",
  "private": true,
  "bin": {
    "facebonk": "./cli.js"
  },
  "exports": {
    ".": "./core/index.js",
    "./core": "./core/index.js",
    "./cli": "./cli/index.js"
  },
  "imports": {
    "crypto": {
      "bare": "bare-crypto",
      "default": "crypto"
    },
    "fs/promises": {
      "bare": "bare-fs/promises",
      "default": "fs/promises"
    },
    "node:crypto": {
      "bare": "bare-crypto",
      "default": "node:crypto"
    },
    "path": {
      "bare": "bare-path",
      "default": "path"
    },
    "os": {
      "bare": "bare-os",
      "default": "os"
    },
    "process": {
      "bare": "bare-process",
      "default": "process"
    }
  },
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "tauri": "tauri",
    "cli": "node cli.js",
    "app:dev": "tauri dev",
    "app:build": "tauri build",
    "postinstall": "npm install --prefix bare",
    "sidecar:debug": "node scripts/prepare-sidecar.mjs --debug",
    "sidecar:release": "node scripts/prepare-sidecar.mjs --release",
    "check": "npm run sidecar:debug && cargo check --manifest-path tauri/Cargo.toml",
    "app:check": "npm run sidecar:debug && cargo check --manifest-path tauri/Cargo.toml",
    "fmt": "cargo fmt --manifest-path tauri/Cargo.toml",
    "schema:build": "node schema.js",
    "test": "npm run schema:build && brittle --timeout 60000 test/*.test.js",
    "start": "node cli.js"
  },
  "dependencies": {
    "autobonk": "file:../autobonk",
    "bare-crypto": "^1.13.4",
    "bare-fs": "^4.5.5",
    "bare-os": "^3.8.0",
    "bare-path": "^3.0.0",
    "bare-process": "^4.3.0",
    "hyperblobs": "^2.8.0",
    "hyperdb": "^4.19.1",
    "hyperdispatch": "^1.4.4",
    "hyperschema": "^1.17.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "brittle": "^3.19.1"
  }
}
