{
  "name": "facebonk",
  "productName": "Facebonk",
  "version": "0.1.0",
  "description": "Peer-to-peer identity manager with shared core, CLI, and local desktop app",
  "type": "module",
  "main": "electron/main.cjs",
  "private": true,
  "bin": {
    "facebonk": "./cli.js"
  },
  "exports": {
    ".": "./core/index.js",
    "./core": "./core/index.js",
    "./cli": "./cli/index.js",
    "./consumer-core": "./consumer-core/index.js",
    "./consumer-electron": "./consumer-electron/index.js"
  },
  "imports": {
    "crypto": {
      "bare": "bare-crypto",
      "default": "crypto"
    },
    "fs/promises": {
      "bare": "bare-fs/promises",
      "default": "fs/promises"
    },
    "node:crypto": {
      "bare": "bare-crypto",
      "default": "node:crypto"
    },
    "path": {
      "bare": "bare-path",
      "default": "path"
    },
    "os": {
      "bare": "bare-os",
      "default": "os"
    },
    "process": {
      "bare": "bare-process",
      "default": "process"
    }
  },
  "scripts": {
    "dev": "electron-forge start -- --no-updates",
    "start": "npm run dev",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "cli": "node cli.js",
    "app:dev": "npm run dev",
    "app:package": "npm run package",
    "app:make": "npm run make",
    "postinstall": "npm install --prefix bare",
    "check": "npm test",
    "app:check": "npm test",
    "schema:build": "node schema.js",
    "test": "npm run schema:build && brittle --timeout 60000 test/*.test.js"
  },
  "dependencies": {
    "autobonk": "file:../autobonk",
    "bare-crypto": "^1.13.4",
    "bare-fs": "^4.5.5",
    "bare-os": "^3.8.0",
    "bare-path": "^3.0.0",
    "bare-process": "^4.3.0",
    "hyperblobs": "^2.8.0",
    "hyperdb": "^4.19.1",
    "hyperdispatch": "^1.4.4",
    "hyperschema": "^1.17.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@forkprince/electron-forge-maker-appimage": "^1.0.11",
    "brittle": "^3.19.1",
    "electron": "^41.2.0",
    "electron-forge-plugin-prune-prebuilds": "^1.0.1",
    "electron-forge-plugin-universal-prebuilds": "^1.0.0"
  }
}
